---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline> window.FontAwesomeConfig = { autoReplaceSvg: 'nest'};</script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
    <style is:global>
        ::-webkit-scrollbar { display: none; }

        @keyframes breathe {
            0%   { transform: scale(1);   opacity: 0.18; }
            40%  { transform: scale(1.45); opacity: 0.32; }
            60%  { transform: scale(1.45); opacity: 0.32; }
            100% { transform: scale(1);   opacity: 0.18; }
        }
        @keyframes breathe-mid {
            0%   { transform: scale(1);   opacity: 0.22; }
            40%  { transform: scale(1.38); opacity: 0.38; }
            60%  { transform: scale(1.38); opacity: 0.38; }
            100% { transform: scale(1);   opacity: 0.22; }
        }
        @keyframes breathe-inner {
            0%   { transform: scale(1);   opacity: 0.55; box-shadow: 0 0 32px 8px rgba(240,180,80,0.18); }
            40%  { transform: scale(1.28); opacity: 0.85; box-shadow: 0 0 72px 28px rgba(240,180,80,0.38); }
            60%  { transform: scale(1.28); opacity: 0.85; box-shadow: 0 0 72px 28px rgba(240,180,80,0.38); }
            100% { transform: scale(1);   opacity: 0.55; box-shadow: 0 0 32px 8px rgba(240,180,80,0.18); }
        }
        @keyframes breathe-label {
            0%   { opacity: 0; }
            10%  { opacity: 1; }
            38%  { opacity: 1; }
            50%  { opacity: 0; }
            58%  { opacity: 1; }
            88%  { opacity: 1; }
            100% { opacity: 0; }
        }
        @keyframes fade-up {
            from { opacity: 0; transform: translateY(22px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @keyframes fade-in {
            from { opacity: 0; }
            to   { opacity: 1; }
        }
        @keyframes subtle-float {
            0%, 100% { transform: translateY(0px); }
            50%       { transform: translateY(-8px); }
        }

        .breathe-outer {
            animation: breathe 7s ease-in-out infinite;
        }
        .breathe-mid {
            animation: breathe-mid 7s ease-in-out infinite;
        }
        .breathe-inner {
            animation: breathe-inner 7s ease-in-out infinite;
        }
        .breathe-label {
            animation: breathe-label 7s ease-in-out infinite;
        }
        .fade-up-1 { animation: fade-up 1.1s ease forwards; opacity: 0; animation-delay: 0.2s; }
        .fade-up-2 { animation: fade-up 1.1s ease forwards; opacity: 0; animation-delay: 0.65s; }
        .fade-up-3 { animation: fade-up 1.1s ease forwards; opacity: 0; animation-delay: 1.1s; }
        .fade-up-4 { animation: fade-up 1.1s ease forwards; opacity: 0; animation-delay: 1.55s; }
        .fade-in-slow { animation: fade-in 2.2s ease forwards; opacity: 0; animation-delay: 2s; }

        .cta-btn {
            transition: background 0.4s ease, box-shadow 0.4s ease, transform 0.3s ease;
        }
        .cta-btn:hover {
            background: rgba(240,160,50,0.28) !important;
            box-shadow: 0 0 48px 8px rgba(240,160,50,0.22);
            transform: translateY(-2px);
        }

        .scroll-hint {
            animation: subtle-float 3s ease-in-out infinite;
        }

        .tagline-dot {
            display: inline-block;
            width: 5px;
            height: 5px;
            background: #f0a832;
            border-radius: 50%;
            margin: 0 10px;
            vertical-align: middle;
            opacity: 0.6;
        }
    </style>
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'sanctuary-bg':     '#fdf6e8',
                        'sanctuary-card':   '#faefd4',
                        'sanctuary-border': '#f5dfa8',
                        'sage':             '#f0a832',
                        'sage-dim':         '#e07c20',
                        'cream':            '#5a3a10',
                        'cream-dim':        '#8a6030',
                        'terracotta':       '#e05c20',
                        'amber-soft':       '#f5c050',
                    },
                    fontFamily: {
                        'serif':  ['Lora', 'Georgia', 'serif'],
                        'sans':   ['Inter', 'system-ui', 'sans-serif'],
                    },
                }
            }
        }
    </script>
</head>
<body class="bg-sanctuary-bg font-sans overflow-x-hidden">

    <!-- Main Landing Page -->
    <main id="landing-page" class="relative min-h-[1080px] w-full flex flex-col items-center justify-center" style="background: radial-gradient(ellipse 80% 70% at 50% 50%, #fef3d0 0%, #fde8b0 55%, #fad898 100%);">

        <!-- Ambient background texture -->
        <div id="bg-texture" class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 60% 50% at 50% 40%, rgba(240,180,80,0.18) 0%, transparent 70%);"></div>

        <!-- Breathing circle — centered background motif -->
        <div id="breathing-motif" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none select-none flex items-center justify-center" style="width: 640px; height: 640px;">
            <!-- Outer ring -->
            <div class="breathe-outer absolute rounded-full border border-amber-400/30" style="width: 560px; height: 560px; border-color: rgba(240,168,50,0.22);"></div>
            <!-- Mid ring -->
            <div class="breathe-mid absolute rounded-full" style="width: 400px; height: 400px; border: 1px solid rgba(224,124,32,0.28);"></div>
            <!-- Inner glow circle -->
            <div class="breathe-inner absolute rounded-full" style="width: 220px; height: 220px; background: radial-gradient(circle, rgba(245,192,80,0.38) 0%, rgba(240,160,50,0.16) 60%, transparent 100%);"></div>
        </div>

        <!-- Breathing label (synced) -->
        <div id="breathe-text-label" class="breathe-label absolute pointer-events-none select-none" style="top: calc(50% + 148px); left: 50%; transform: translateX(-50%);">
            <span class="font-sans text-xs tracking-[0.35em] uppercase" style="color: rgba(180,100,20,0.55);">breathe</span>
        </div>

        <!-- Content container -->
        <div id="content-center" class="relative z-10 flex flex-col items-center justify-center text-center px-6 md:px-12" style="max-width: 860px;">

            <!-- Wordmark / micro brand -->
            <div id="wordmark" class="fade-up-1 mb-14 md:mb-16">
                <span class="font-serif text-sm md:text-base tracking-[0.28em] uppercase font-normal italic" style="color: rgba(180,100,20,0.65);">The Attention Sanctuary</span>
            </div>

            <!-- Primary headline -->
            <h1 id="headline" class="fade-up-2 font-serif leading-[1.18] mb-6 md:mb-8" style="font-size: clamp(2.6rem, 5.5vw, 5rem); font-weight: 500; letter-spacing: -0.01em; color: #4a2c08;">
                What does your<br>
                <em style="font-style: italic; color: #c96a18;">mind need</em> right now?
            </h1>

            <!-- Subline -->
            <p id="subline" class="fade-up-3 font-sans leading-relaxed mb-14 md:mb-16" style="font-size: clamp(1rem, 1.5vw, 1.2rem); font-weight: 300; letter-spacing: 0.01em; max-width: 520px; color: #8a6030;">
                A quiet space to recover your focus.<br class="hidden md:block"> No noise. No rush. Just you.
            </p>

            <!-- Primary CTA -->
            <div id="cta-container" class="fade-up-4 flex flex-col items-center gap-5">
                <button id="enter-btn" class="cta-btn font-sans border rounded-2xl px-12 md:px-16 py-5 md:py-6 tracking-[0.12em] uppercase text-sm md:text-base" style="background: rgba(240,160,50,0.14); border-color: rgba(220,140,40,0.45); color: #5a3a10; letter-spacing: 0.14em; font-weight: 400;">
                    Enter the Sanctuary
                </button>
                <span class="font-sans text-xs tracking-widest uppercase" style="font-size: 0.68rem; letter-spacing: 0.22em; color: rgba(138,96,48,0.5);">
                    No account needed &nbsp;·&nbsp; Free to begin
                </span>
            </div>

        </div>

        <!-- Ambient tagline strip — bottom -->
        <div id="bottom-tagline" class="fade-in-slow absolute bottom-10 left-0 right-0 flex items-center justify-center gap-0 pointer-events-none select-none">
            <span class="font-sans text-xs tracking-[0.22em] uppercase" style="color: rgba(90,58,16,0.35);">Breathe</span>
            <span class="tagline-dot mx-3"></span>
            <span class="font-sans text-xs tracking-[0.22em] uppercase" style="color: rgba(90,58,16,0.35);">Focus</span>
            <span class="tagline-dot mx-3"></span>
            <span class="font-sans text-xs tracking-[0.22em] uppercase" style="color: rgba(90,58,16,0.35);">Restore</span>
        </div>

        <!-- Subtle scroll / proceed hint -->
        <div id="scroll-hint" class="fade-in-slow scroll-hint absolute bottom-20 right-12 hidden xl:flex flex-col items-center gap-2 pointer-events-none select-none" style="opacity: 0.38;">
            <div class="w-px h-10" style="background: rgba(200,130,40,0.5);"></div>
            <span class="font-sans text-xs tracking-widest uppercase" style="font-size: 0.6rem; writing-mode: vertical-rl; letter-spacing: 0.25em; color: rgba(180,110,30,0.7);">Scroll</span>
        </div>

    </main>

    <script is:inline>
        const btn = document.getElementById('enter-btn');
        if (btn) {
            btn.addEventListener('click', function() {
                this.textContent = 'Opening your sanctuary…';
                this.style.opacity = '0.6';
                this.style.pointerEvents = 'none';
                setTimeout(() => { window.location.href = '/dashboard'; }, 600);
            });
        }

        // Cycle breathing label between "breathe" and "hold"
        const breatheLabel = document.getElementById('breathe-text-label');
        const labels = ['breathe', 'hold', 'release'];
        let labelIdx = 0;
        setInterval(() => {
            labelIdx = (labelIdx + 1) % labels.length;
            if (breatheLabel) {
                breatheLabel.querySelector('span').textContent = labels[labelIdx];
            }
        }, 7000 / labels.length);
    </script>


</body>
</html>