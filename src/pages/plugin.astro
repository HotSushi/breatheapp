<script is:inline>
    // ── Slide carousel ──
    let currentSlide = 0;
    const slides = document.querySelectorAll('.feature-slide');
    const dots   = document.querySelectorAll('.dot-indicator');
    let autoTimer;

    function goToSlide(idx) {
        slides[currentSlide].classList.remove('active');
        dots[currentSlide].classList.remove('active');
        currentSlide = idx;
        slides[currentSlide].classList.add('active');
        slides[currentSlide].classList.remove('slide-animate');
        void slides[currentSlide].offsetWidth;
        slides[currentSlide].classList.add('slide-animate');
        dots[currentSlide].classList.add('active');
    }

    function startAuto() { autoTimer = setInterval(() => goToSlide((currentSlide + 1) % slides.length), 4000); }
    function stopAuto()  { clearInterval(autoTimer); }

    dots.forEach((d, i) => d.addEventListener('click', () => { stopAuto(); goToSlide(i); startAuto(); }));
    startAuto();

    // ── Sign-up form ──
    function handleSignup() {
        const input = document.getElementById('email-input');
        const email = input.value.trim();
        if (!email || !email.includes('@')) {
            input.style.borderColor = 'rgba(201,106,24,.55)';
            input.style.boxShadow   = '0 0 0 3px rgba(240,168,50,.12)';
            input.placeholder = 'Please enter a valid email…';
            setTimeout(() => {
                input.style.borderColor = '';
                input.style.boxShadow   = '';
                input.placeholder = 'Enter your email address…';
            }, 2500);
            return;
        }
        document.getElementById('form-container').style.display = 'none';
        document.getElementById('success-state').classList.remove('hidden');
    }
</script>

</body>
