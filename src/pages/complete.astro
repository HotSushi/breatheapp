---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Complete</title>
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline> window.FontAwesomeConfig = { autoReplaceSvg: 'nest'};</script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
    <style is:global>
        ::-webkit-scrollbar { display: none; }

        @keyframes breathe-ambient {
            0%   { transform: scale(1);   opacity: 0.12; }
            45%  { transform: scale(1.18); opacity: 0.22; }
            60%  { transform: scale(1.18); opacity: 0.22; }
            100% { transform: scale(1);   opacity: 0.12; }
        }
        @keyframes breathe-ambient-mid {
            0%   { transform: scale(1);   opacity: 0.15; }
            45%  { transform: scale(1.12); opacity: 0.28; }
            60%  { transform: scale(1.12); opacity: 0.28; }
            100% { transform: scale(1);   opacity: 0.15; }
        }
        @keyframes fade-up {
            from { opacity: 0; transform: translateY(24px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @keyframes fade-in {
            from { opacity: 0; }
            to   { opacity: 1; }
        }
        @keyframes shimmer-line {
            0%   { opacity: 0.3; transform: scaleX(0.6); }
            50%  { opacity: 0.7; transform: scaleX(1); }
            100% { opacity: 0.3; transform: scaleX(0.6); }
        }
        @keyframes success-bloom {
            0%   { transform: scale(0.7); opacity: 0; }
            60%  { transform: scale(1.06); opacity: 1; }
            100% { transform: scale(1); opacity: 1; }
        }
        @keyframes ring-expand {
            0%   { transform: scale(0.8); opacity: 0; }
            50%  { opacity: 0.35; }
            100% { transform: scale(1.5); opacity: 0; }
        }
        @keyframes check-draw {
            from { stroke-dashoffset: 40; opacity: 0; }
            to   { stroke-dashoffset: 0; opacity: 1; }
        }
        @keyframes gentle-pulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(240,168,50,0); }
            50%       { box-shadow: 0 0 30px 6px rgba(240,168,50,0.1); }
        }
        @keyframes divider-grow {
            from { transform: scaleX(0); opacity: 0; }
            to   { transform: scaleX(1); opacity: 1; }
        }

        .ambient-outer { animation: breathe-ambient 9s ease-in-out infinite; }
        .ambient-mid   { animation: breathe-ambient-mid 9s ease-in-out infinite; }

        .fade-up-1  { animation: fade-up 1s ease forwards; opacity: 0; animation-delay: 0.1s; }
        .fade-up-2  { animation: fade-up 1s ease forwards; opacity: 0; animation-delay: 0.3s; }
        .fade-up-3  { animation: fade-up 1s ease forwards; opacity: 0; animation-delay: 0.55s; }
        .fade-up-4  { animation: fade-up 1s ease forwards; opacity: 0; animation-delay: 0.75s; }
        .fade-up-5  { animation: fade-up 1s ease forwards; opacity: 0; animation-delay: 0.95s; }
        .fade-up-6  { animation: fade-up 1s ease forwards; opacity: 0; animation-delay: 1.15s; }
        .fade-in-late { animation: fade-in 1.4s ease forwards; opacity: 0; animation-delay: 1.4s; }

        .success-icon-wrap { animation: success-bloom 1s cubic-bezier(0.34,1.56,0.64,1) forwards; opacity: 0; animation-delay: 0.2s; }
        .ring-pulse-1 { animation: ring-expand 2.2s ease-out forwards; animation-delay: 0.6s; }
        .ring-pulse-2 { animation: ring-expand 2.2s ease-out forwards; animation-delay: 1.0s; }

        .check-path {
            stroke-dasharray: 40;
            stroke-dashoffset: 40;
            animation: check-draw 0.6s ease forwards;
            animation-delay: 0.7s;
        }

        .shimmer-line { animation: shimmer-line 4s ease-in-out infinite; }

        .reg-card { animation: gentle-pulse 5s ease-in-out infinite; }

        .wordmark-link { transition: opacity 0.3s ease; }
        .wordmark-link:hover { opacity: 0.7; }

        .tagline-dot {
            display: inline-block;
            width: 4px; height: 4px;
            background: #f0a832;
            border-radius: 50%;
            margin: 0 10px;
            vertical-align: middle;
            opacity: 0.5;
        }

        .nav-item { transition: color 0.3s ease, opacity 0.3s ease; cursor: pointer; }
        .nav-item:hover { opacity: 0.75; }

        .oauth-btn {
            transition: background 0.4s ease, border-color 0.4s ease, transform 0.3s ease;
            cursor: pointer;
        }
        .oauth-btn:hover {
            background: rgba(240,168,50,0.1) !important;
            border-color: rgba(220,140,40,0.3) !important;
            transform: translateY(-2px);
        }

        .email-input {
            background: rgba(240,168,50,0.06);
            border: 1px solid rgba(220,140,40,0.22);
            border-radius: 16px;
            color: #4a2c08;
            font-family: 'Inter', sans-serif;
            font-size: 0.9rem;
            font-weight: 300;
            letter-spacing: 0.01em;
            transition: border-color 0.4s ease, background 0.4s ease, box-shadow 0.4s ease;
            outline: none;
        }
        .email-input::placeholder { color: rgba(138,96,48,0.45); }
        .email-input:focus {
            border-color: rgba(220,140,40,0.45);
            background: rgba(240,168,50,0.1);
            box-shadow: 0 0 0 3px rgba(240,168,50,0.1);
        }

        .cta-btn {
            background: rgba(240,168,50,0.18);
            border: 1px solid rgba(220,140,40,0.42);
            border-radius: 16px;
            transition: background 0.4s ease, border-color 0.4s ease, transform 0.3s ease, box-shadow 0.4s ease;
            cursor: pointer;
        }
        .cta-btn:hover {
            background: rgba(240,168,50,0.28);
            border-color: rgba(220,140,40,0.6);
            transform: translateY(-2px);
            box-shadow: 0 8px 32px rgba(240,168,50,0.18);
        }

        .skip-link {
            transition: opacity 0.3s ease;
            cursor: pointer;
        }
        .skip-link:hover { opacity: 0.7; }

        .divider-line {
            animation: divider-grow 0.8s ease forwards;
            opacity: 0;
            animation-delay: 1.2s;
            transform-origin: center;
        }

        .benefit-item { transition: opacity 0.3s ease; }
        .benefit-item:hover { opacity: 0.85; }
    </style>
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'sanctuary-bg':     '#fdf6e8',
                        'sanctuary-card':   '#faefd4',
                        'sanctuary-border': '#f5dfa8',
                        'sage':             '#f0a832',
                        'sage-dim':         '#e07c20',
                        'cream':            '#4a2c08',
                        'cream-dim':        '#8a6030',
                        'terracotta':       '#e05c20',
                        'amber-soft':       '#f5c050',
                    },
                    fontFamily: {
                        'serif':  ['Lora', 'Georgia', 'serif'],
                        'sans':   ['Inter', 'system-ui', 'sans-serif'],
                    },
                }
            }
        }
    </script>
</head>
<body class="bg-sanctuary-bg font-sans overflow-x-hidden">

    <main id="success-screen" class="relative w-full flex flex-col items-center justify-center" style="min-height: 1080px; background: radial-gradient(ellipse 90% 80% at 50% 50%, #fef3d0 0%, #fde8b0 55%, #fad898 100%);">

        <div id="bg-texture" class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 55% 45% at 50% 38%, rgba(240,180,80,0.18) 0%, transparent 70%);"></div>

        <div id="ambient-motif" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none select-none flex items-center justify-center" style="width: 900px; height: 900px;">
            <div class="ambient-outer absolute rounded-full border" style="width: 820px; height: 820px; border-color: rgba(220,140,40,0.18);"></div>
            <div class="ambient-mid absolute rounded-full border" style="width: 600px; height: 600px; border-color: rgba(200,120,30,0.15);"></div>
        </div>

        <div id="wordmark-top" class="fade-up-1 absolute top-10 left-0 right-0 flex items-center justify-center pointer-events-none select-none">
            <span class="wordmark-link font-serif text-sm tracking-[0.28em] uppercase font-normal italic pointer-events-auto" style="color: rgba(180,100,20,0.65);">The Attention Sanctuary</span>
        </div>

        <nav id="top-nav" class="fade-up-1 absolute top-9 right-10 hidden lg:flex items-center gap-8">
            <a href="/" class="nav-item font-sans text-xs tracking-[0.2em] uppercase" style="font-weight:300;letter-spacing:0.2em;color:rgba(90,58,16,0.4);text-decoration:none;">Home</a>
            <a href="/dashboard" class="nav-item font-sans text-xs tracking-[0.2em] uppercase" style="font-weight:300;letter-spacing:0.2em;color:rgba(90,58,16,0.4);text-decoration:none;">Dashboard</a>
            <a href="/plugin" class="nav-item font-sans text-xs tracking-[0.2em] uppercase" style="font-weight:300;letter-spacing:0.2em;color:rgba(90,58,16,0.4);text-decoration:none;">Plugin</a>
            <span class="nav-item font-sans text-xs tracking-[0.2em] uppercase pb-0.5" style="font-weight: 400; letter-spacing: 0.2em; color: rgba(180,100,20,0.85); border-bottom: 1px solid rgba(220,140,40,0.45);">Complete</span>
        </nav>

        <div id="success-content" class="relative z-10 flex flex-col items-center w-full px-6 md:px-12 xl:px-0" style="max-width: 620px; padding-top: 110px; padding-bottom: 80px;">

            <div id="success-celebration" class="fade-up-2 flex flex-col items-center text-center mb-10">

                <div class="relative flex items-center justify-center mb-8" style="width: 96px; height: 96px;">
                    <div class="ring-pulse-1 absolute rounded-full border" style="width: 96px; height: 96px; border-color: rgba(220,140,40,0.45);"></div>
                    <div class="ring-pulse-2 absolute rounded-full border" style="width: 96px; height: 96px; border-color: rgba(240,168,50,0.3);"></div>
                    <div class="success-icon-wrap relative flex items-center justify-center rounded-full" style="width: 72px; height: 72px; background: radial-gradient(circle, rgba(240,180,80,0.28) 0%, rgba(240,168,50,0.1) 70%, transparent 100%); border: 1px solid rgba(220,140,40,0.35);">
                        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path class="check-path" d="M7 14.5 L12 19.5 L21 9" stroke="#c96a18" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                </div>

                <div class="mb-5 flex items-center gap-3">
                    <div class="shimmer-line h-px w-10 origin-right" style="background: rgba(220,140,40,0.45);"></div>
                    <span class="font-sans text-xs tracking-[0.3em] uppercase" style="font-weight: 300; letter-spacing: 0.3em; color: rgba(180,100,20,0.6);">Practice complete</span>
                    <div class="shimmer-line h-px w-10 origin-left" style="background: rgba(220,140,40,0.45);"></div>
                </div>

                <h1 class="font-serif leading-[1.25] mb-4" style="font-size: clamp(1.9rem, 3.2vw, 3rem); font-weight: 500; letter-spacing: -0.01em; color: #4a2c08;">
                    You returned<br>
                    <em style="font-style: italic; color: #c96a18;">to yourself.</em>
                </h1>

                <p class="font-sans leading-relaxed" style="font-size: clamp(0.88rem, 1.2vw, 1.02rem); font-weight: 300; letter-spacing: 0.01em; max-width: 400px; color: rgba(138,96,48,0.75);">
                    That was a meaningful act of care. Your attention is worth protecting — not just today, but every time you open a new tab.
                </p>
            </div>

            <div id="divider-section" class="fade-up-3 w-full flex items-center gap-5 mb-10">
                <div class="divider-line flex-1 h-px" style="background: rgba(220,140,40,0.2);"></div>
                <span class="font-sans text-xs tracking-[0.25em] uppercase flex-shrink-0" style="font-size: 0.65rem; font-weight: 300; letter-spacing: 0.25em; color: rgba(90,58,16,0.38);">protect your attention, always</span>
                <div class="divider-line flex-1 h-px" style="background: rgba(220,140,40,0.2);"></div>
            </div>

            <div id="registration-card" class="reg-card fade-up-4 w-full rounded-3xl border px-8 md:px-10 py-9 md:py-10 mb-6" style="background: rgba(255,248,230,0.65); border-color: rgba(220,140,40,0.22); border-radius: 28px; backdrop-filter: blur(4px);">

                <div id="reg-card-header" class="mb-7 text-center">
                    <h2 class="font-serif mb-2" style="font-size: clamp(1.15rem, 1.8vw, 1.45rem); font-weight: 500; letter-spacing: -0.005em; color: #4a2c08;">
                        Make this your default state
                    </h2>
                    <p class="font-sans leading-relaxed" style="font-size: clamp(0.8rem, 1.05vw, 0.92rem); font-weight: 300; max-width: 380px; margin: 0 auto; color: rgba(138,96,48,0.72);">
                        Create a free account to automatically intercept distraction the next time you reach for your phone or open a new tab.
                    </p>
                </div>

                <div id="oauth-options" class="flex flex-col sm:flex-row gap-3 mb-6">
                    <button id="btn-google" class="oauth-btn flex-1 flex items-center justify-center gap-3 rounded-2xl border px-5 py-3.5" style="background: rgba(240,168,50,0.06); border-color: rgba(220,140,40,0.2); border-radius: 16px;">
                        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4" opacity="0.9"/>
                            <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z" fill="#34A853" opacity="0.9"/>
                            <path d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05" opacity="0.9"/>
                            <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z" fill="#EA4335" opacity="0.9"/>
                        </svg>
                        <span class="font-sans text-sm" style="font-weight: 300; letter-spacing: 0.02em; color: rgba(74,44,8,0.75);">Continue with Google</span>
                    </button>

                    <button id="btn-apple" class="oauth-btn flex-1 flex items-center justify-center gap-3 rounded-2xl border px-5 py-3.5" style="background: rgba(240,168,50,0.06); border-color: rgba(220,140,40,0.2); border-radius: 16px;">
                        <i class="fa-brands fa-apple text-base" style="color: rgba(74,44,8,0.7);"></i>
                        <span class="font-sans text-sm" style="font-weight: 300; letter-spacing: 0.02em; color: rgba(74,44,8,0.75);">Continue with Apple</span>
                    </button>
                </div>

                <div id="email-divider" class="flex items-center gap-4 mb-6">
                    <div class="flex-1 h-px" style="background: rgba(220,140,40,0.18);"></div>
                    <span class="font-sans text-xs tracking-widest uppercase flex-shrink-0" style="font-size: 0.65rem; font-weight: 300; letter-spacing: 0.22em; color: rgba(90,58,16,0.4);">or with email</span>
                    <div class="flex-1 h-px" style="background: rgba(220,140,40,0.18);"></div>
                </div>

                <div id="email-form" class="flex flex-col sm:flex-row gap-3">
                    <input
                        id="email-input"
                        type="email"
                        placeholder="your@email.com"
                        class="email-input flex-1 px-5 py-3.5"
                        style="min-width: 0;"
                    />
                    <button id="btn-email-signup" class="cta-btn flex-shrink-0 flex items-center justify-center gap-2.5 px-6 py-3.5">
                        <span class="font-sans text-sm" style="font-weight: 400; letter-spacing: 0.04em; color: #5a3a10;">Protect my attention</span>
                        <i class="fa-solid fa-arrow-right text-xs" style="color: rgba(180,100,20,0.8);"></i>
                    </button>
                </div>

                <div id="privacy-note" class="mt-5 text-center">
                    <p class="font-sans leading-relaxed" style="font-size: 0.7rem; font-weight: 300; letter-spacing: 0.04em; color: rgba(90,58,16,0.38);">
                        No spam. No notifications. No dark patterns. Just a quiet space, whenever you need it.
                    </p>
                </div>
            </div>

            <div id="benefits-strip" class="fade-up-5 w-full flex flex-col sm:flex-row items-start sm:items-center justify-center gap-5 sm:gap-8 mb-10 px-2">
                <div class="benefit-item flex items-center gap-2.5">
                    <div class="flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center" style="background: rgba(240,168,50,0.15); border: 1px solid rgba(220,140,40,0.3);">
                        <i class="fa-solid fa-check" style="font-size: 0.55rem; color: rgba(180,100,20,0.8);"></i>
                    </div>
                    <span class="font-sans text-xs" style="font-weight: 300; letter-spacing: 0.04em; font-size: 0.78rem; color: rgba(138,96,48,0.65);">Browser extension included</span>
                </div>
                <div class="benefit-item flex items-center gap-2.5">
                    <div class="flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center" style="background: rgba(240,168,50,0.15); border: 1px solid rgba(220,140,40,0.3);">
                        <i class="fa-solid fa-check" style="font-size: 0.55rem; color: rgba(180,100,20,0.8);"></i>
                    </div>
                    <span class="font-sans text-xs" style="font-weight: 300; letter-spacing: 0.04em; font-size: 0.78rem; color: rgba(138,96,48,0.65);">All exercises unlocked</span>
                </div>
                <div class="benefit-item flex items-center gap-2.5">
                    <div class="flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center" style="background: rgba(240,168,50,0.15); border: 1px solid rgba(220,140,40,0.3);">
                        <i class="fa-solid fa-check" style="font-size: 0.55rem; color: rgba(180,100,20,0.8);"></i>
                    </div>
                    <span class="font-sans text-xs" style="font-weight: 300; letter-spacing: 0.04em; font-size: 0.78rem; color: rgba(138,96,48,0.65);">Always free to start</span>
                </div>
            </div>

            <div id="skip-section" class="fade-in-late flex flex-col items-center gap-2 text-center">
                <span class="skip-link font-sans text-xs tracking-[0.12em]" style="font-size: 0.75rem; font-weight: 300; letter-spacing: 0.12em; color: rgba(90,58,16,0.38);">
                    Not ready yet? <a href="/dashboard" style="color:rgba(90,58,16,0.55);text-decoration:underline;text-decoration-color:rgba(220,140,40,0.3);text-underline-offset:2px;">Return to dashboard</a>
                </span>
                <div class="mt-3 flex items-center gap-0">
                    <span class="font-sans text-xs tracking-[0.22em] uppercase" style="font-size: 0.62rem; color: rgba(90,58,16,0.28);">Breathe</span>
                    <span class="tagline-dot"></span>
                    <span class="font-sans text-xs tracking-[0.22em] uppercase" style="font-size: 0.62rem; color: rgba(90,58,16,0.28);">Focus</span>
                    <span class="tagline-dot"></span>
                    <span class="font-sans text-xs tracking-[0.22em] uppercase" style="font-size: 0.62rem; color: rgba(90,58,16,0.28);">Restore</span>
                </div>
            </div>

        </div>

        <div id="left-accent" class="fade-in-late absolute left-10 top-1/2 -translate-y-1/2 hidden xl:flex flex-col items-center gap-3 pointer-events-none select-none" style="opacity: 0.35;">
            <div class="w-px h-16" style="background: rgba(200,130,40,0.4);"></div>
            <span class="font-sans text-xs tracking-widest uppercase" style="font-size: 0.58rem; writing-mode: vertical-rl; letter-spacing: 0.3em; transform: rotate(180deg); color: rgba(180,110,30,0.7);">Complete</span>
            <div class="w-px h-16" style="background: rgba(200,130,40,0.4);"></div>
        </div>

    </main>

    <script is:inline>
        const emailInput = document.getElementById('email-input');
        const emailBtn = document.getElementById('btn-email-signup');

        emailBtn.addEventListener('click', function() {
            const val = emailInput.value.trim();
            if (!val || !val.includes('@')) {
                emailInput.style.borderColor = 'rgba(224,92,32,0.55)';
                emailInput.style.boxShadow = '0 0 0 3px rgba(224,92,32,0.1)';
                emailInput.focus();
                setTimeout(() => {
                    emailInput.style.borderColor = '';
                    emailInput.style.boxShadow = '';
                }, 2000);
                return;
            }
            emailBtn.innerHTML = '<span class="font-sans text-sm" style="font-weight:400;letter-spacing:0.04em;color:#5a3a10;">Welcome home</span><i class="fa-solid fa-check text-xs" style="color:rgba(180,100,20,0.8);"></i>';
            emailBtn.style.pointerEvents = 'none';
            emailBtn.style.background = 'rgba(240,168,50,0.28)';
        });

        const oauthBtns = document.querySelectorAll('.oauth-btn');
        oauthBtns.forEach(btn => {
            btn.addEventListener('click', function() {
                const label = this.querySelector('span');
                if (label) {
                    const original = label.textContent;
                    label.textContent = 'Connecting…';
                    this.style.pointerEvents = 'none';
                    setTimeout(() => {
                        label.textContent = original;
                        this.style.pointerEvents = '';
                    }, 2500);
                }
            });
        });

        const skipLink = document.querySelector('.skip-link');
        if (skipLink) {
            skipLink.addEventListener('click', function() {
                this.style.opacity = '0.4';
            });
        }
    </script>


  
</body>
</html>