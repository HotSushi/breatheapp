            </div>

            <!-- Divider -->
            <div class="cp-fi-3 mb-8" style="width:64px;height:1px;background:rgba(220,140,40,.35);"></div>

            <!-- Actions -->
            <div class="cp-fi-3 flex flex-col items-center gap-4">
                <button onclick="tryAnotherPractice()" class="cp-pill font-sans text-xs tracking-[.22em] uppercase flex items-center gap-3 px-10 py-4 rounded-full border"
                        style="min-width:260px;justify-content:center;background:rgba(255,248,230,.80);border-color:rgba(197,131,76,.40);color:#4a2c08;font-weight:500;">
                    <span>Try Another Practice</span>
                    <i class="fa-solid fa-arrow-right" style="color:#c96a18;font-size:.7rem;"></i>
                </button>
                <div class="cp-fi-4">
                    <a href="/plugin" class="font-sans italic" style="font-size:.75rem;font-weight:300;color:rgba(138,96,48,.52);text-decoration:underline;text-decoration-color:rgba(220,140,40,.30);text-underline-offset:3px;transition:color .2s;letter-spacing:.03em;"
                       onmouseover="this.style.color='rgba(138,96,48,.85)'" onmouseout="this.style.color='rgba(138,96,48,.52)'">
                        Want to track your progress? Get the plugin
                    </a>
                </div>
            </div>

            <!-- Bottom dots -->
            <div class="cp-fi-4 absolute bottom-8 left-1/2 -translate-x-1/2 flex gap-2 items-center" style="opacity:.28;">
                <span style="width:5px;height:5px;border-radius:50%;background:#c96a18;display:inline-block;"></span>
                <span style="width:24px;height:1px;background:rgba(220,140,40,.6);display:inline-block;"></span>
                <span style="width:5px;height:5px;border-radius:50%;background:#c96a18;display:inline-block;"></span>
            </div>

        </div><!-- /view-complete -->

        </section>

        <!-- RIGHT PANEL 40% -->
        <aside class="flex flex-col w-full lg:w-[40%] px-8 md:px-12 xl:px-14 py-12"
               style="background: linear-gradient(160deg, #fef6e4 0%, #faefd4 100%); min-height:640px;">

            <!-- Header -->
            <div class="fu2 mb-10">
                <div class="flex items-center gap-3 mb-5">
                    <div class="shimmer h-px w-6" style="background:var(--accent-border); transform-origin:right;"></div>
                    <span class="font-sans text-xs tracking-[.28em] uppercase" style="font-weight:300;color:var(--text-muted);">Choose your practice</span>
                </div>
                <h1 class="font-serif leading-[1.22] mb-3" style="font-size:clamp(1.5rem,2.1vw,2.3rem);font-weight:500;color:var(--text);">
                    What does your<br>
                    mind <em style="font-style:italic;color:var(--accent);">need right now?</em>
                </h1>
                <p class="font-sans" style="font-size:.85rem;font-weight:300;color:var(--text-muted);line-height:1.65;max-width:310px;">
                    Three gentle exercises to help you return to yourself.
                </p>
            </div>

            <!-- Nav cards -->
            <div class="flex flex-col gap-3 flex-1">

                <div id="card-calm" class="sr1 nav-card" onclick="switchView('calm')">
                    <div class="flex items-center gap-4">
                        <div class="nav-icon"><i class="fa-solid fa-lungs"></i></div>
                        <div class="nav-card-text">
                            <div class="flex items-center gap-2 mb-0.5">
                                <h3 class="font-serif" style="font-size:1rem;font-weight:500;color:var(--text);">Calm My Body</h3>
                                <span id="badge-calm" class="hidden font-sans" style="font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:#c96a18;background:rgba(253,246,232,0.95);border:1px solid rgba(201,106,24,.30);padding:2px 8px;border-radius:9999px;">Active</span>
                            </div>
                            <p class="font-sans" style="font-size:.76rem;font-weight:300;color:var(--text-muted);">Guided breathing cycle · 3 minutes</p>
                        </div>
                    </div>
                    <i class="fa-solid fa-arrow-right nav-arrow"></i>
                </div>

                <div id="card-focus" class="sr2 nav-card" onclick="switchView('focus')">
                    <div class="flex items-center gap-4">
                        <div class="nav-icon"><i class="fa-solid fa-brain"></i></div>
                        <div class="nav-card-text">
                            <div class="flex items-center gap-2 mb-0.5">
                                <h3 class="font-serif" style="font-size:1rem;font-weight:500;color:var(--text);">Reset My Focus</h3>
                                <span id="badge-focus" class="hidden font-sans" style="font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:#c96a18;background:rgba(253,246,232,0.95);border:1px solid rgba(201,106,24,.30);padding:2px 8px;border-radius:9999px;">Active</span>
                            </div>
                            <p class="font-sans" style="font-size:.76rem;font-weight:300;color:var(--text-muted);">60-Word Daily Reading · 3 minutes</p>
                        </div>
                    </div>
                    <i class="fa-solid fa-arrow-right nav-arrow"></i>
                </div>

                <div id="card-head" class="sr3 nav-card" onclick="switchView('head')">
                    <div class="flex items-center gap-4">
                        <div class="nav-icon"><i class="fa-solid fa-leaf"></i></div>
                        <div class="nav-card-text">
                            <div class="flex items-center gap-2 mb-0.5">
                                <h3 class="font-serif" style="font-size:1rem;font-weight:500;color:var(--text);">Clear My Head</h3>
                                <span id="badge-head" class="hidden font-sans" style="font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:#c96a18;background:rgba(253,246,232,0.95);border:1px solid rgba(201,106,24,.30);padding:2px 8px;border-radius:9999px;">Active</span>
                            </div>
                            <p class="font-sans" style="font-size:.76rem;font-weight:300;color:var(--text-muted);">Thought Dissolver · 5 minutes</p>
                        </div>
                    </div>
                    <i class="fa-solid fa-arrow-right nav-arrow"></i>
                </div>
            </div>

            <!-- Footer -->
            <div class="fi mt-10">
                <div class="h-px w-full mb-4" style="background:var(--divider)"></div>
                <p class="font-sans mb-3" style="font-size:.68rem;font-weight:300;color:rgba(100,70,30,.45);line-height:1.7;max-width:280px;">
                    All exercises are free. No account required to begin. Your focus is the only thing that matters here.
                </p>
                <div class="flex items-center gap-0">
                    <span class="font-sans uppercase" style="font-size:.58rem;letter-spacing:.22em;color:rgba(100,70,30,.35);">Breathe</span>
                    <span style="display:inline-block;width:4px;height:4px;border-radius:50%;background:var(--accent);opacity:.4;margin:0 9px;vertical-align:middle;"></span>
                    <span class="font-sans uppercase" style="font-size:.58rem;letter-spacing:.22em;color:rgba(100,70,30,.35);">Focus</span>
                    <span style="display:inline-block;width:4px;height:4px;border-radius:50%;background:var(--accent);opacity:.4;margin:0 9px;vertical-align:middle;"></span>
                    <span class="font-sans uppercase" style="font-size:.58rem;letter-spacing:.22em;color:rgba(100,70,30,.35);">Restore</span>
                </div>
            </div>
        </aside>

    </main>
</div>

<script is:inline>
// ─────────────────────────────────────────────
//  VIEW SWITCHING
// ─────────────────────────────────────────────
const VIEWS = ['calm','focus','head'];
let lastActiveView = 'calm';
let activeView = 'calm';

function tryAnotherPractice() {
    const cv = document.getElementById('view-complete');
    cv.classList.add('hidden'); cv.classList.remove('flex');
    const idx = VIEWS.indexOf(activeView);
    const nextView = VIEWS[(idx + 1) % VIEWS.length];
    switchView(nextView);
}

function showComplete() {
    VIEWS.forEach(v => {
        const el = document.getElementById('view-' + v);
        el.classList.add('hidden'); el.classList.remove('flex');
        document.getElementById('card-' + v).classList.remove('active');
        document.getElementById('badge-' + v).classList.add('hidden');
    });
    const cv = document.getElementById('view-complete');
    cv.classList.remove('hidden'); cv.classList.add('flex');
    // Re-trigger entrance animations
    cv.querySelectorAll('[class*="cp-fi"],[class*="cp-check"],[class*="cp-ring"]').forEach(el => {
        const anim = el.style.animation || getComputedStyle(el).animation;
        el.style.animation = 'none';
        el.offsetHeight;
        el.style.animation = '';
    });
}

function switchView(key) {
    if (key === activeView) return;
    lastActiveView = activeView;
    activeView = key;

    VIEWS.forEach(v => {
        const el = document.getElementById('view-' + v);
        el.classList.add('hidden');
        el.classList.remove('flex');
        document.getElementById('card-' + v).classList.remove('active');
        document.getElementById('badge-' + v).classList.add('hidden');
    });

    const view = document.getElementById('view-' + key);
    view.classList.remove('hidden');
    view.classList.add('flex');
    document.getElementById('card-' + key).classList.add('active');
    document.getElementById('badge-' + key).classList.remove('hidden');

    if (key === 'calm')  {
        calmRunning = false; clearInterval(calmInterval); clearTimeout(phaseTimeout);
        const app = document.getElementById('breathing-app');
        if (app) { app.classList.remove('state-inhale','state-hold','state-exhale','state-rest','is-paused'); }
        document.getElementById('calm-btn').style.display = '';
        document.getElementById('calm-btn').textContent = 'Begin Session';
        document.getElementById('countdown').textContent = '3:00'; calmSeconds = 180;
        const cc = document.getElementById('calm-continue');
        cc.classList.add('hidden'); cc.classList.remove('flex');
    }
    if (key === 'focus') { initFocus(); }
    if (key === 'head')  { initHead(); }
}

// set initial active state
document.getElementById('card-calm').classList.add('active');
document.getElementById('badge-calm').classList.remove('hidden');

// ─────────────────────────────────────────────
//  CALM MY BODY
// ─────────────────────────────────────────────
const breathPhases = [
    { name:'Inhale',  sub:'Fill your lungs slowly',  dot:'dot-inhale', ms:4000, state:'state-inhale' },
    { name:'Hold',    sub:'Stay still',               dot:'dot-hold',   ms:2000, state:'state-hold'   },
    { name:'Exhale',  sub:'Release everything',       dot:'dot-exhale', ms:4000, state:'state-exhale' },
    { name:'Rest',    sub:'Prepare to begin',         dot:'dot-rest',   ms:2000, state:'state-rest'   },
];
let phaseIdx = 0, phaseTimeout = null, calmRunning = false, calmInterval = null, calmSeconds = 180;

function runPhase() {
    if (!calmRunning) return;
    const idx = phaseIdx % breathPhases.length;
    const p = breathPhases[idx];
    document.getElementById('phase-text').textContent = p.name;
    document.getElementById('phase-sub').textContent  = p.sub;
    ['dot-inhale','dot-hold','dot-exhale','dot-rest'].forEach(id => {
        document.getElementById(id).style.background = 'var(--divider)';
    });
    document.getElementById(p.dot).style.background = 'var(--accent)';

    // Sync circle state
    const app = document.getElementById('breathing-app');
    if (app) {
        app.classList.remove('state-inhale','state-hold','state-exhale','state-rest');
        app.classList.add(p.state);
    }

    phaseIdx++;
    phaseTimeout = setTimeout(runPhase, p.ms);
}

function toggleCalm() {
    const btn = document.getElementById('calm-btn');
    if (!calmRunning) {
        calmRunning = true;
        document.getElementById('breathing-app')?.classList.remove('is-paused');
        btn.textContent = 'Pause';
        runPhase();
        calmInterval = setInterval(() => {
            if (calmSeconds <= 0) {
                clearInterval(calmInterval); calmRunning = false;
                btn.style.display = 'none';
                document.getElementById('countdown').textContent = '0:00';
                clearTimeout(phaseTimeout);
                showComplete(); return;
            }
            calmSeconds--;
            const m = Math.floor(calmSeconds/60), s = calmSeconds%60;
            document.getElementById('countdown').textContent = `${m}:${s.toString().padStart(2,'0')}`;
        }, 1000);
    } else {
        calmRunning = false;
        clearInterval(calmInterval); clearTimeout(phaseTimeout);
        document.getElementById('breathing-app')?.classList.add('is-paused');
        btn.textContent = 'Resume';
    }
}

// ─────────────────────────────────────────────
//  RESET MY FOCUS
// ─────────────────────────────────────────────
const readings = [
    {
        pillar: 'Neuroscience',
        text: 'Your brain\'s default mode network activates during passive scrolling, reinforcing habitual, low-effort thinking. To shift into focused cognition, you must deliberately engage the central executive network — the system responsible for reasoning, planning, and sustained attention. Even a single act of careful reading, done slowly and with intention, can trigger this transition. Focus is not a personality trait. It is a neurological state you can choose to enter.',
        question: 'According to the passage, what is focus?',
        options: [
            { text: 'A fixed personality trait some people are born with',   correct: false },
            { text: 'A neurological state you can deliberately choose to enter', correct: true  },
            { text: 'A result of avoiding social media entirely',             correct: false },
            { text: 'An instinct that only activates under stress',          correct: false },
        ],
    },
    {
        pillar: 'Stoic Philosophy',
        text: 'Marcus Aurelius wrote that the impediment to action advances action — what stands in the way becomes the way. Distraction is not an obstacle to your day. It is a signal that your attention has drifted from what matters. Every moment you choose to return to presence, however briefly, you are practicing the discipline that separates deliberate living from drifting. The return itself is the practice.',
        question: 'What does distraction signal, according to this passage?',
        options: [
            { text: 'A failure of willpower',                             correct: false },
            { text: 'That your attention has drifted from what matters',  correct: true  },
            { text: 'An irreversible loss of focus',                      correct: false },
            { text: 'The brain entering deep rest',                       correct: false },
        ],
    },
    {
        pillar: 'Cognitive Psychology',
        text: 'Attention is a finite resource, not a moral virtue. Cognitive load theory shows the brain can hold roughly four chunks of information in working memory at once. When you fragment your focus across multiple streams — notifications, feeds, conversations — you deplete this resource without replenishing it. A deliberate pause, like this one, begins the restoration process. Depth requires protection, not motivation.',
        question: 'What does this passage say begins the restoration of depleted attention?',
        options: [
            { text: 'Increasing motivation and willpower',       correct: false },
            { text: 'Expanding working memory capacity',         correct: false },
            { text: 'Taking a deliberate pause',                 correct: true  },
            { text: 'Reducing notification volume',             correct: false },
        ],
    },
];

let focusTimerInterval = null;
let currentReading = null;

function initFocus() {
    currentReading = readings[Math.floor(Math.random() * readings.length)];

    document.getElementById('pillar-label').textContent = currentReading.pillar;
    const wc = currentReading.text.split(/\s+/).length;
    document.getElementById('word-count').textContent   = wc + ' words';
    document.getElementById('reading-para').textContent  = currentReading.text;
    document.getElementById('question-text').textContent = currentReading.question;

    // Build answer options
    const wrap = document.getElementById('answer-wrap');
    wrap.innerHTML = '';
    currentReading.options.forEach((opt, i) => {
        const btn = document.createElement('button');
        btn.className = 'ans-btn';
        btn.dataset.correct = opt.correct;
        btn.innerHTML = `<span class="letter-badge">${String.fromCharCode(65+i)}</span><span>${opt.text}</span>`;
        btn.addEventListener('click', handleFocusAnswer);
        wrap.appendChild(btn);
    });

    // Reset comprehension area
    const ca = document.getElementById('comprehension-area');
    ca.style.opacity = '0'; ca.style.pointerEvents = 'none';
    ca.classList.remove('unlock-pop');
    document.getElementById('focus-feedback').classList.add('hidden');
    document.getElementById('focus-continue').classList.add('hidden');

    // Re-arm timer bar
    clearInterval(focusTimerInterval);
    const barParent = document.getElementById('timer-bar').parentElement;
    const oldBar = document.getElementById('timer-bar');
    const newBar = document.createElement('div');
    newBar.id = 'timer-bar'; newBar.className = 'timer-bar h-full rounded-sm';
    newBar.style.background = 'var(--accent)'; newBar.style.width = '100%';
    barParent.replaceChild(newBar, oldBar);

    let secs = 17;
    focusTimerInterval = setInterval(() => {
        secs--;
        if (secs <= 0) {
            clearInterval(focusTimerInterval);
            unlockComprehension();
        }
    }, 1000);
}

function unlockComprehension() {
    const ca = document.getElementById('comprehension-area');
    ca.style.opacity = '1'; ca.style.pointerEvents = 'auto';
    ca.classList.add('unlock-pop');
}

function handleFocusAnswer(e) {
    const btn = e.currentTarget;
    const correct = btn.dataset.correct === 'true';
    document.querySelectorAll('.ans-btn').forEach(b => { b.disabled = true; b.style.opacity = '.5'; });
    btn.style.opacity = '1';
    const fb = document.getElementById('focus-feedback');
    const ft = document.getElementById('focus-feedback-text');
    fb.classList.remove('hidden');
    if (correct) {
        btn.classList.add('correct');
        fb.style.borderColor = 'rgba(34,197,94,.35)'; fb.style.background = 'rgba(34,197,94,.07)';
        ft.innerHTML = '<strong style="font-weight:500;">Well done.</strong> Your central executive network is fully engaged.';
        document.getElementById('focus-continue').classList.remove('hidden');
    } else {
        btn.classList.add('wrong');
        document.querySelectorAll('.ans-btn').forEach(b => { if (b.dataset.correct==='true') { b.classList.add('correct'); b.style.opacity='1'; } });
        fb.style.borderColor = 'rgba(220,80,60,.25)'; fb.style.background = 'var(--card-bg)';
        ft.textContent = 'Not quite — your brain is still buzzing. Take a deep breath and try another approach.';
        setTimeout(() => {
            const rb = document.createElement('button');
            rb.className = 'font-sans text-xs tracking-widest uppercase mt-4 px-6 py-2.5 rounded-full';
            rb.style.cssText = 'font-weight:400;color:var(--text);background:var(--accent-light);border:1px solid var(--accent-border);cursor:pointer;display:block;';
            rb.textContent = 'Try another reading';
            rb.onclick = initFocus;
            fb.appendChild(rb);
        }, 600);
    }
}

// ─────────────────────────────────────────────
//  CLEAR MY HEAD
// ─────────────────────────────────────────────
const SIZES    = [.96, .84, .75, .68, .62, .58];
const OPACITIES= [.88, .72, .58, .47, .38, .32];
let thoughtsList = [];

function initHead() {
    thoughtsList = [];
    document.getElementById('thought-pile').innerHTML = '';
    document.getElementById('thought-ta').value = '';
    const tw = document.getElementById('ta-wrap');
    tw.style.display = ''; tw.style.opacity = '1';
    const aw = document.getElementById('add-wrap');
    aw.style.display = ''; aw.style.opacity = '1';
    const rw = document.getElementById('release-wrap');
    rw.classList.add('hidden');
    rw.style.opacity = ''; rw.style.display = ''; rw.style.transition = '';
    const cs = document.getElementById('cleared-state');
    cs.classList.add('hidden'); cs.classList.remove('flex');
}

function addThought() {
    const ta = document.getElementById('thought-ta');
    const text = ta.value.trim();
    if (!text) return;

    thoughtsList.forEach(item => {
        item.depth++;
        const i = Math.min(item.depth, SIZES.length-1);
        item.el.style.fontSize = SIZES[i] + 'rem';
        item.el.style.opacity  = OPACITIES[i];
    });

    const el = document.createElement('div');
    el.className = 'thought-item font-serif';
    el.style.cssText = `font-size:${SIZES[0]}rem;opacity:${OPACITIES[0]};color:var(--text);line-height:1.65;padding:1px 0;`;
    el.textContent = text;
    document.getElementById('thought-pile').prepend(el);
    thoughtsList.push({ text, el, depth: 0 });

    ta.value = ''; ta.focus();
    document.getElementById('release-wrap').classList.remove('hidden');
}

function releaseThoughts() {
    if (!thoughtsList.length) return;
    const pile = document.getElementById('thought-pile');
    burstParticles(pile);

    const fade = el => { el.style.transition='opacity .35s ease'; el.style.opacity='0'; };
    fade(document.getElementById('ta-wrap'));
    fade(document.getElementById('add-wrap'));
    fade(document.getElementById('release-wrap'));

    thoughtsList.forEach((item, i) => {
        const dx = (Math.random()-.5)*80;
        item.el.style.setProperty('--dx', dx+'px');
        item.el.style.animationDelay = (i*65)+'ms';
        item.el.classList.add('thought-dissolving');
    });

    setTimeout(() => {
        pile.innerHTML = ''; thoughtsList = [];
        document.getElementById('ta-wrap').style.display   = 'none';
        document.getElementById('add-wrap').style.display  = 'none';
        document.getElementById('release-wrap').classList.add('hidden');
        showComplete();
    }, thoughtsList.length * 65 + 1150);
}

function burstParticles(container) {
    const r = container.getBoundingClientRect();
    const cx = r.left + r.width/2, cy = r.top + r.height/2;
    for (let i=0; i<28; i++) {
        const d = document.createElement('div');
        const sz = 2 + Math.random()*3.5;
        d.style.cssText = `position:fixed;width:${sz}px;height:${sz}px;border-radius:50%;background:rgba(192,120,56,${.4+Math.random()*.5});left:${cx}px;top:${cy}px;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);`;
        document.body.appendChild(d);
        const angle = (i/28)*Math.PI*2 + (Math.random()-.5)*.5;
        const dist  = 50 + Math.random()*110;
        d.animate(
            [{transform:'translate(-50%,-50%) scale(1)',opacity:.9},
             {transform:`translate(calc(-50% + ${Math.cos(angle)*dist}px),calc(-50% + ${Math.sin(angle)*dist - 80}px)) scale(0)`,opacity:0}],
            {duration: 700+Math.random()*400, easing:'ease-out', delay:Math.random()*220}
        ).onfinish = ()=>d.remove();
    }
}

document.getElementById('thought-ta').addEventListener('keydown', e => {
    if (e.key==='Enter' && !e.shiftKey) { e.preventDefault(); addThought(); }
});
</script>


