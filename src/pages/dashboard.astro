                <div class="cp-ring2 absolute rounded-full border" style="width:100px;height:100px;border-color:rgba(197,131,76,.25);"></div>
                <div class="cp-check relative flex items-center justify-center rounded-full"
                     style="width:72px;height:72px;background:rgba(240,168,50,.12);border:1.5px solid rgba(197,131,76,.35);">
                    <i class="fa-solid fa-check" style="font-size:1.4rem;color:#c96a18;"></i>
                </div>
            </div>

            <!-- Label -->
            <div class="cp-fi-1 flex items-center gap-3 mb-6">
                <span class="h-px w-8" style="background:rgba(220,140,40,.40);display:inline-block;"></span>
                <span class="font-sans text-xs tracking-[.25em] uppercase" style="font-weight:400;color:rgba(180,100,20,.60);">Practice Complete</span>
                <span class="h-px w-8" style="background:rgba(220,140,40,.40);display:inline-block;"></span>
            </div>

            <!-- Headline -->
            <div class="cp-fi-2 mb-5">
                <h1 class="font-serif leading-tight mb-4" style="font-size:clamp(2.2rem,4vw,3.2rem);font-weight:500;color:#2e2620;">
                    Your mind is<br><em style="font-style:italic;color:#c96a18;">yours again.</em>
                </h1>
                <p class="font-sans uppercase tracking-[.18em] leading-relaxed" style="font-size:.72rem;font-weight:400;color:rgba(138,96,48,.55);max-width:320px;margin:0 auto;">
