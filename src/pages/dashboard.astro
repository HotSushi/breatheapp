---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard — The Attention Sanctuary</title>
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
    <style is:global>
        *, *::before, *::after { box-sizing: border-box; }
        ::-webkit-scrollbar { display: none; }

        :root {
            --bg:            #fdf6e8;
            --text:          #4a2c08;
            --text-mid:      #8a6030;
            --text-muted:    #9a7850;
            --accent:        #f0a832;
            --accent-dark:   #c96a18;
            --accent-light:  rgba(240,168,50,0.18);
            --accent-border: rgba(220,140,40,0.50);
            --card-bg:       rgba(254,246,228,0.85);
            --card-border:   rgba(220,168,80,0.30);
            --divider:       rgba(200,130,40,0.28);
        }

        body { background: var(--bg); font-family: 'Inter', system-ui, sans-serif; color: var(--text); }

        /* ── shared fade-ups ── */
        @keyframes fade-up   { from { opacity:0; transform:translateY(18px) } to { opacity:1; transform:translateY(0) } }
        @keyframes fade-in   { from { opacity:0 } to { opacity:1 } }
        @keyframes shimmer   { 0%,100% { opacity:.3; transform:scaleX(.6) } 50% { opacity:.75; transform:scaleX(1) } }
        @keyframes slide-r   { from { opacity:0; transform:translateX(24px) } to { opacity:1; transform:translateX(0) } }

        .fu1 { animation: fade-up  .8s ease forwards; opacity:0; animation-delay:.08s }
        .fu2 { animation: fade-up  .8s ease forwards; opacity:0; animation-delay:.22s }
        .fu3 { animation: fade-up  .8s ease forwards; opacity:0; animation-delay:.36s }
        .fu4 { animation: fade-up  .8s ease forwards; opacity:0; animation-delay:.52s }
        .fi  { animation: fade-in 1.1s ease forwards; opacity:0; animation-delay:.9s  }
        .sr1 { animation: slide-r  .7s ease forwards; opacity:0; animation-delay:.30s }
        .sr2 { animation: slide-r  .7s ease forwards; opacity:0; animation-delay:.46s }
        .sr3 { animation: slide-r  .7s ease forwards; opacity:0; animation-delay:.62s }
        .shimmer { animation: shimmer 4s ease-in-out infinite }

        /* ── breathing circle ── */
        @keyframes br-outer  { 0%,100%{transform:scale(1);opacity:.35} 50%{transform:scale(1.20);opacity:.65} }
        @keyframes br-mid    { 0%,100%{transform:scale(1);opacity:.45} 50%{transform:scale(1.14);opacity:.75} }
        @keyframes br-inner  { 0%,100%{transform:scale(1);opacity:.6 } 50%{transform:scale(1.08);opacity:.95} }
        @keyframes br-core   { 0%,100%{transform:scale(1)} 50%{transform:scale(1.07)} }
        @keyframes br-glow   { 0%,100%{opacity:.2;transform:scale(1)} 50%{opacity:.5;transform:scale(1.22)} }
        @keyframes phase-pulse { 0%,100%{opacity:.55} 50%{opacity:1} }
        .br-outer { animation: br-outer 8s ease-in-out infinite }
        .br-mid   { animation: br-mid   8s ease-in-out infinite }
        .br-inner { animation: br-inner 8s ease-in-out infinite }
        .br-core  { animation: br-core  8s ease-in-out infinite }
        .br-glow  { animation: br-glow  8s ease-in-out infinite }
        .phase-lbl { animation: phase-pulse 8s ease-in-out infinite }

        /* ── reading timer bar ── */
        @keyframes timer-shrink { from{width:100%} to{width:0%} }
        .timer-bar { animation: timer-shrink 17s linear forwards }

        /* ── answer options ── */
        @keyframes unlock-pop { 0%{transform:scale(.9);opacity:0} 70%{transform:scale(1.02)} 100%{transform:scale(1);opacity:1} }
        .unlock-pop { animation: unlock-pop .45s cubic-bezier(.34,1.56,.64,1) forwards }

        .ans-btn {
            display:flex; align-items:center; gap:16px;
            width:100%; text-align:left;
            padding:14px 18px; border-radius:12px;
            background: var(--card-bg); border:1px solid var(--card-border);
            cursor:pointer; transition: background .25s, border-color .25s, transform .18s;
            font-family:'Lora',serif; font-size:.97rem; color:var(--text); line-height:1.5;
        }
        .ans-btn:hover:not(:disabled) { background:rgba(254,246,228,.98); transform:translateX(3px) }
        .ans-btn:disabled { cursor:default }
        .ans-btn.correct { background:rgba(34,197,94,.10)!important; border-color:rgba(34,197,94,.45)!important }
        .ans-btn.wrong   { background:rgba(220,80,60,.08)!important;  border-color:rgba(220,80,60,.35)!important }
        .letter-badge {
            flex-shrink:0; width:30px; height:30px; border-radius:50%;
            border:1px solid var(--accent-border); display:flex; align-items:center; justify-content:center;
            font-family:'Inter',sans-serif; font-size:.68rem; font-weight:500; color:var(--accent);
        }

        /* ── thought dissolver ── */
        @keyframes thought-appear { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
        @keyframes thought-float  {
            0%  { opacity:1; transform:translateY(0) translateX(0) scale(1); filter:blur(0) }
            55% { opacity:.5; transform:translateY(-65px) translateX(var(--dx,0px)) scale(.55); filter:blur(1px) }
            100%{ opacity:0; transform:translateY(-130px) translateX(var(--dx,0px)) scale(.08); filter:blur(5px) }
        }
        @keyframes cleared-rise { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }
        .thought-item { animation: thought-appear .35s ease forwards; transition: font-size .4s ease, opacity .4s ease }
        .thought-dissolving { animation: thought-float 1.05s ease-out forwards!important; transition:none!important }
        .cleared-rise { animation: cleared-rise .7s ease forwards }
        /* ── complete view ── */
        @keyframes success-bloom { 0%{transform:scale(.7);opacity:0} 60%{transform:scale(1.06);opacity:1} 100%{transform:scale(1);opacity:1} }
        @keyframes ring-expand   { 0%{transform:scale(.8);opacity:0} 50%{opacity:.35} 100%{transform:scale(1.5);opacity:0} }
        @keyframes check-draw    { from{stroke-dashoffset:40;opacity:0} to{stroke-dashoffset:0;opacity:1} }
        @keyframes gentle-pulse  { 0%,100%{box-shadow:0 0 0 0 rgba(240,168,50,0)} 50%{box-shadow:0 0 28px 5px rgba(240,168,50,.10)} }
        @keyframes divider-grow  { from{transform:scaleX(0);opacity:0} to{transform:scaleX(1);opacity:1} }

        .ring-pulse-1 { animation: ring-expand 2.2s ease-out forwards; animation-delay:.5s; }
        .ring-pulse-2 { animation: ring-expand 2.2s ease-out forwards; animation-delay:.9s; }
        .success-icon-wrap { animation: success-bloom .9s cubic-bezier(.34,1.56,.64,1) forwards; opacity:0; animation-delay:.3s; }
        .check-path { stroke-dasharray:40; stroke-dashoffset:40; animation: check-draw .55s ease forwards; animation-delay:.75s; }
        .reg-card   { animation: gentle-pulse 5s ease-in-out infinite; }
        .divider-line { animation: divider-grow .7s ease forwards; opacity:0; animation-delay:1.1s; transform-origin:center; }

        .oauth-btn { transition: background .35s, border-color .35s, transform .25s; cursor:pointer; }
        .oauth-btn:hover { background: rgba(240,168,50,.10)!important; border-color:rgba(220,140,40,.30)!important; transform:translateY(-2px); }
        .cv-email-input {
            background:rgba(240,168,50,.06); border:1px solid rgba(220,140,40,.22); border-radius:14px;
            color:#4a2c08; font-family:'Inter',sans-serif; font-size:.9rem; font-weight:300;
            outline:none; transition:border-color .35s,background .35s,box-shadow .35s;
            width:100%; padding:12px 18px;
        }
        .cv-email-input::placeholder { color:rgba(138,96,48,.45); }
        .cv-email-input:focus { border-color:rgba(220,140,40,.45); background:rgba(240,168,50,.10); box-shadow:0 0 0 3px rgba(240,168,50,.10); }
        .cv-cta-btn {
            background:rgba(240,168,50,.18); border:1px solid rgba(220,140,40,.42); border-radius:14px;
            transition:background .35s,border-color .35s,transform .25s,box-shadow .35s; cursor:pointer;
            padding:12px 18px;
        }
        .cv-cta-btn:hover { background:rgba(240,168,50,.28); border-color:rgba(220,140,40,.60); transform:translateY(-2px); box-shadow:0 8px 28px rgba(240,168,50,.18); }

        #thought-ta {
            background: transparent; border:none; outline:none; resize:none;
            font-family:'Lora',serif; font-size:1.05rem; font-weight:400; color:var(--text);
            width:100%; line-height:1.7;
        }
        #thought-ta::placeholder { color:rgba(100,70,30,.38); font-style:italic }

        /* ── nav cards ── */
        .nav-card {
            display:flex; align-items:center; gap:16px;
            padding:18px 20px; border-radius:14px;
            border:1px solid var(--card-border);
            background:rgba(254,243,208,0.35);
            cursor:pointer;
            transition: background .3s, border-color .3s, transform .25s, box-shadow .3s;
        }
        .nav-card:hover { transform:translateX(3px); background:rgba(254,243,208,0.65) }
        .nav-card.active {
            background: rgba(240,168,50,0.18)!important;
            border-color: rgba(220,140,40,0.55)!important;
            box-shadow: 0 4px 28px rgba(240,168,50,0.15), inset 0 0 20px rgba(240,168,50,0.05);
        }
        .nav-icon {
            flex-shrink:0; width:48px; height:48px; border-radius:10px;
            background:rgba(240,168,50,0.18); border:1px solid rgba(220,140,40,0.30);
            display:flex; align-items:center; justify-content:center; font-size:1.3rem;
        }
    </style>
    <script is:inline>
        tailwind.config = {
            theme: { extend: {
                fontFamily: { serif:['Lora','Georgia','serif'], sans:['Inter','system-ui','sans-serif'] }
            }}
        }
    </script>
</head>
<body style="background:var(--bg); min-height:100vh;">

<div class="flex flex-col" style="min-height:100vh;">

    <!-- ── Top bar ── -->
    <header class="fu1 flex items-center justify-between px-10 pt-7 pb-5" style="border-bottom:1px solid var(--divider);">
        <span class="font-serif text-sm tracking-[.26em] uppercase italic" style="color:var(--text-muted); font-weight:400;">The Attention Sanctuary</span>
        <nav class="hidden md:flex items-center gap-8">
            <a href="/" class="font-sans text-xs tracking-[.2em] uppercase" style="font-weight:300; color:var(--text-muted); text-decoration:none; transition:color .25s" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">Home</a>
            <span class="font-sans text-xs tracking-[.2em] uppercase" style="font-weight:500; color:var(--accent); border-bottom:1.5px solid var(--accent); padding-bottom:2px;">Dashboard</span>
            <a href="/plugin" class="font-sans text-xs tracking-[.2em] uppercase" style="font-weight:300; color:var(--muted, #9a7850); text-decoration:none; transition:color .25s;" onmouseover="this.style.color='var(--text, #4a2c08)'" onmouseout="this.style.color='var(--muted, #9a7850)'">Plugin</a>
        </nav>
    </header>

    <!-- ── Main layout ── -->
    <main class="flex flex-1 flex-col lg:flex-row" style="min-height:0;">

        <!-- LEFT PANEL 60% -->
        <section id="left-panel" class="relative flex flex-col items-center justify-center w-full lg:w-[60%] px-8 md:px-14 py-12"
                 style="background: radial-gradient(ellipse 80% 70% at 50% 50%, #fef3d0 0%, #fde8b0 60%, #fad898 100%); border-right:1px solid var(--divider); min-height:640px; overflow:hidden;">

            <!-- Gateway side label -->
            <div class="absolute left-5 top-1/2 -translate-y-1/2 hidden xl:flex flex-col items-center gap-2 pointer-events-none select-none" style="opacity:.22;">
                <div class="w-px h-10" style="background:var(--accent)"></div>
                <span class="font-sans" style="font-size:.5rem; writing-mode:vertical-rl; transform:rotate(180deg); letter-spacing:.3em; text-transform:uppercase; color:var(--accent-dark);">Gateway</span>
                <div class="w-px h-10" style="background:var(--accent)"></div>
            </div>

            <!-- Ambient centre glow -->
            <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 55% 50% at 50% 50%, rgba(240,180,80,.18) 0%, transparent 70%);"></div>

            <!-- ══ VIEW 1: CALM MY BODY ══ -->
            <div id="view-calm" class="flex flex-col items-center w-full" style="max-width:480px;">

                <div class="fu2 flex items-center gap-3 mb-8">
                    <div class="shimmer h-px w-8" style="background:var(--accent-border); transform-origin:right;"></div>
                    <span class="font-sans text-xs tracking-[.28em] uppercase" style="font-weight:300; color:var(--text-muted);">Breathing Circle</span>
                    <div class="shimmer h-px w-8" style="background:var(--accent-border); transform-origin:left;"></div>
                </div>

                <div class="fu3 relative flex items-center justify-center mb-10" style="width:300px;height:300px;">
                    <div class="br-glow absolute rounded-full" style="width:280px;height:280px;background:radial-gradient(circle,rgba(240,168,50,.35) 0%,transparent 70%);"></div>
                    <div class="br-outer absolute rounded-full" style="width:268px;height:268px;border:1.5px solid rgba(220,140,40,.30);"></div>
                    <div class="br-mid   absolute rounded-full" style="width:210px;height:210px;border:1.5px solid rgba(235,155,40,.45);"></div>
                    <div class="br-inner absolute rounded-full" style="width:152px;height:152px;border:2px solid rgba(240,168,50,.65);"></div>
                    <div class="br-core  absolute rounded-full flex items-center justify-center"
                         style="width:96px;height:96px;background:radial-gradient(circle,rgba(240,168,50,.55) 0%,rgba(245,192,80,.25) 70%);border:1.5px solid rgba(220,140,40,.50);">
                        <span style="font-size:1.8rem;">🫁</span>
                    </div>
                </div>

                <div class="fu4 flex flex-col items-center gap-2 mb-6">
                    <h2 id="phase-text" class="phase-lbl font-serif" style="font-size:clamp(1.5rem,2.2vw,2rem);font-weight:500;color:var(--text);">Breathe In</h2>
                    <p id="phase-sub" class="font-sans" style="font-size:.8rem;font-weight:300;letter-spacing:.08em;color:var(--text-muted);">Follow the expanding circle</p>
                </div>

                <div class="fi flex items-center gap-3 mb-8">
                    <div class="flex flex-col items-center gap-1.5">
                        <div id="dot-inhale" class="w-2 h-2 rounded-full" style="background:var(--accent);"></div>
                        <span class="font-sans" style="font-size:.55rem;letter-spacing:.2em;text-transform:uppercase;color:var(--text-muted);">Inhale</span>
                    </div>
                    <div class="h-px w-6" style="background:var(--divider)"></div>
                    <div class="flex flex-col items-center gap-1.5">
                        <div id="dot-hold" class="w-2 h-2 rounded-full" style="background:var(--divider);"></div>
                        <span class="font-sans" style="font-size:.55rem;letter-spacing:.2em;text-transform:uppercase;color:var(--text-muted);">Hold</span>
                    </div>
                    <div class="h-px w-6" style="background:var(--divider)"></div>
                    <div class="flex flex-col items-center gap-1.5">
                        <div id="dot-exhale" class="w-2 h-2 rounded-full" style="background:var(--divider);"></div>
                        <span class="font-sans" style="font-size:.55rem;letter-spacing:.2em;text-transform:uppercase;color:var(--text-muted);">Exhale</span>
                    </div>
                    <div class="h-px w-6" style="background:var(--divider)"></div>
                    <div class="flex flex-col items-center gap-1.5">
                        <div id="dot-rest" class="w-2 h-2 rounded-full" style="background:var(--divider);"></div>
                        <span class="font-sans" style="font-size:.55rem;letter-spacing:.2em;text-transform:uppercase;color:var(--text-muted);">Rest</span>
                    </div>
                </div>

                <div class="fi flex flex-col items-center gap-3">
                    <div id="countdown" class="font-sans" style="font-size:2.2rem;font-weight:300;color:var(--accent);letter-spacing:.04em;">4:00</div>
                    <button id="calm-btn" onclick="toggleCalm()"
                        class="font-sans text-xs tracking-[.22em] uppercase px-8 py-3 rounded-full"
                        style="font-weight:400;color:var(--text);background:var(--accent-light);border:1px solid var(--accent-border);cursor:pointer;transition:background .3s;"
                        onmouseover="this.style.background='rgba(192,120,56,.26)'" onmouseout="this.style.background='var(--accent-light)'">
                        Begin Session
                    </button>
                </div>
            </div>

            <!-- ══ VIEW 2: RESET MY FOCUS ══ -->
            <div id="view-focus" class="hidden flex-col w-full" style="max-width:580px;">

                <!-- Reading card -->
                <div id="reading-card" class="rounded-2xl overflow-hidden mb-7"
                     style="background:var(--card-bg); border:1px solid var(--card-border); box-shadow:0 2px 24px rgba(0,0,0,.05);">

                    <div class="px-8 pt-7 pb-6">
                        <div class="flex items-center justify-between mb-5">
                            <span id="pillar-label" class="font-sans text-xs tracking-[.25em] uppercase" style="font-weight:400;color:var(--text-muted);">Neuroscience</span>
                            <span id="word-count"   class="font-sans text-xs tracking-[.15em] uppercase" style="font-weight:300;color:var(--text-muted);">68 words</span>
                        </div>
                        <div class="h-px w-full mb-7" style="background:var(--divider)"></div>
                        <p id="reading-para" class="font-serif leading-[1.82]" style="font-size:clamp(1rem,1.5vw,1.15rem);font-weight:400;color:var(--text);"></p>
                    </div>

                    <!-- Timer bar — amber bottom border that shrinks -->
                    <div style="height:4px;background:rgba(192,120,56,.15);">
                        <div id="timer-bar" class="timer-bar h-full rounded-sm" style="background:var(--accent);width:100%;"></div>
                    </div>
                </div>

                <!-- Comprehension check — locked until timer expires -->
                <div id="comprehension-area" style="opacity:0;pointer-events:none;transition:opacity .4s ease;">

                    <div class="flex items-center gap-3 mb-5">
                        <div class="w-2 h-2 rounded-full flex-shrink-0" style="background:var(--accent);"></div>
                        <span class="font-sans text-xs tracking-[.22em] uppercase" style="font-weight:500;color:var(--accent);">Comprehension Check</span>
                    </div>

                    <h3 id="question-text" class="font-serif mb-2" style="font-size:1.15rem;font-weight:500;color:var(--text);line-height:1.5;"></h3>
                    <p class="font-sans mb-6" style="font-size:.8rem;font-weight:300;color:var(--text-muted);">Select the answer that best reflects what you just read.</p>

                    <div id="answer-wrap" class="flex flex-col gap-3"></div>

                    <div id="focus-feedback" class="hidden mt-5 px-5 py-4 rounded-xl"
                         style="border:1px solid var(--card-border); background:var(--card-bg);">
                        <p id="focus-feedback-text" class="font-sans text-sm leading-relaxed" style="font-weight:300;color:var(--text);"></p>
                    </div>

                    <div id="focus-continue" class="hidden mt-6 flex justify-center">
                        <button onclick="showComplete()"
                           class="font-sans text-xs tracking-[.22em] uppercase px-8 py-3 rounded-full"
                           style="font-weight:400;color:var(--text);background:var(--accent-light);border:1px solid var(--accent-border);cursor:pointer;transition:background .3s;"
                           onmouseover="this.style.background='rgba(240,168,50,.30)'" onmouseout="this.style.background='var(--accent-light)'">
                            Continue →
                        </button>
                    </div>
                </div>
            </div>

            <!-- ══ VIEW 3: CLEAR MY HEAD ══ -->
            <div id="view-head" class="hidden flex-col items-center w-full" style="max-width:560px;">

                <!-- Label -->
                <div class="fu2 flex items-center gap-4 mb-8 w-full justify-center">
                    <div class="shimmer h-px flex-1" style="background:var(--divider); max-width:80px; transform-origin:right;"></div>
                    <span class="font-sans text-xs tracking-[.28em] uppercase" style="font-weight:400;color:var(--text-muted);">Thought Dissolver</span>
                    <div class="shimmer h-px flex-1" style="background:var(--divider); max-width:80px; transform-origin:left;"></div>
                </div>

                <!-- Two-line headline -->
                <div class="fu3 mb-8 text-center">
                    <h2 class="font-serif leading-[1.25]" style="font-size:clamp(1.6rem,2.5vw,2.3rem);font-weight:500;color:var(--text);">
                        Type the exact thought, distraction,
                    </h2>
                    <h2 class="font-serif leading-[1.25]" style="font-size:clamp(1.6rem,2.5vw,2.3rem);font-weight:500;font-style:italic;color:var(--accent);">
                        or worry pulling your attention away.
                    </h2>
                </div>

                <!-- Thought pile -->
                <div id="thought-pile" class="w-full mb-1 flex flex-col gap-0.5" style="min-height:4px;"></div>

                <!-- Textarea with organic circle watermark -->
                <div id="ta-wrap" class="relative w-full mb-1" style="min-height:120px;">
                    <!-- decorative circle -->
                    <div class="absolute inset-0 flex items-center justify-center pointer-events-none" style="opacity:.06;">
                        <div class="rounded-full" style="width:200px;height:200px;border:1.5px solid var(--accent);"></div>
                    </div>
                    <div class="absolute inset-0 flex items-center justify-center pointer-events-none" style="opacity:.04;">
                        <div class="rounded-full" style="width:140px;height:140px;border:1px solid var(--accent);"></div>
                    </div>
                    <textarea id="thought-ta" rows="4" placeholder="It feels like…"></textarea>
                </div>
                <!-- bottom line -->
                <div class="w-full h-px mb-6" style="background:rgba(192,120,56,.30);"></div>

                <!-- Add to pile -->
                <div id="add-wrap" class="flex justify-center mb-6">
                    <button onclick="addThought()"
                        class="font-sans text-xs tracking-[.2em] uppercase px-6 py-2.5 rounded-full flex items-center gap-2"
                        style="font-weight:400;color:var(--accent-dark);background:transparent;border:1.5px solid rgba(220,140,40,.45);cursor:pointer;transition:background .25s;"
                        onmouseover="this.style.background='rgba(240,168,50,.18)'" onmouseout="this.style.background='transparent'">
                        <span style="font-size:.9rem;">⊞</span> Add to Pile
                    </button>
                </div>

                <!-- Release It — shown once ≥1 thought -->
                <div id="release-wrap" class="hidden w-full">
                    <button onclick="releaseThoughts()"
                        class="w-full font-serif flex items-center justify-center gap-3 py-4 rounded-2xl"
